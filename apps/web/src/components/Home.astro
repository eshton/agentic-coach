---
import Layout from "../layouts/Layout.astro";
import { ui, brand, type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = ui[lang];

const homePath = lang === "en" ? "/" : "/hu/";
const altLang: Lang = lang === "en" ? "hu" : "en";
const altPath = altLang === "en" ? "/" : "/hu/";
---

<Layout title={t.meta.title} description={t.meta.description} lang={t.htmlLang}>
  <header class="nav">
    <div class="container nav-inner">
      <a class="brand" href={homePath}>{brand}</a>
      <nav class="nav-links">
        <a href="#problem">{t.nav.problem}</a>
        <a href="#method">{t.nav.method}</a>
        <a href="#work">{t.nav.work}</a>
      </nav>
      <div class="lang-switch">
        <span aria-current="true">{lang.toUpperCase()}</span>
        <span class="sep">/</span>
        <a href={altPath} hreflang={altLang}>{altLang.toUpperCase()}</a>
      </div>
      <a class="btn primary nav-cta" href="#contact">{t.nav.cta}</a>
    </div>
  </header>

  <main>
    <!-- Hero -->
    <section class="hero">
      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">{t.hero.eyebrow}</p>
          <h1 set:html={t.hero.headline} />
          <p class="subhead">{t.hero.subhead}</p>
          <div class="cta-row">
            <a class="btn primary" href="#contact">{t.hero.ctaPrimary}</a>
            <a class="btn" href="#method">{t.hero.ctaSecondary}</a>
          </div>
          <p class="sign" aria-hidden="true">{t.hero.sign}</p>
        </div>
        <figure class="portrait">
          <div class="portrait-frame">
            <img src="/agoston.webp" alt={t.hero.portraitCaption} width="560" height="560" />
          </div>
          <figcaption>{t.hero.portraitCaption}</figcaption>
        </figure>
      </div>
    </section>

    <!-- Problem -->
    <section id="problem" class="band">
      <div class="container">
        <p class="eyebrow">{t.problem.eyebrow}</p>
        <h2 class="band-title">{t.problem.title}</h2>
        <div class="cards">
          {
            t.problem.items.map((p) => (
              <article class="card">
                <h3>{p.title}</h3>
                <p>{p.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Method -->
    <section id="method" class="band tinted">
      <div class="container">
        <p class="eyebrow">{t.method.eyebrow}</p>
        <h2 class="band-title">{t.method.title}</h2>
        <p class="band-lede">{t.method.lede}</p>

        <h3 class="sub">{t.method.loopSub}</h3>
        <ol class="loop">
          {
            t.method.loop.map(([step, desc], i) => (
              <li class="loop-step">
                <span class="loop-num">{String(i + 1).padStart(2, "0")}</span>
                <span class="loop-name">{step}</span>
                <span class="loop-desc">{desc}</span>
              </li>
            ))
          }
        </ol>

        <h3 class="sub">{t.method.ladderSub}</h3>
        <div class="ladder">
          {
            t.method.levels.map(([lvl, name, desc], i) => (
              <div class="rung" style={`--i:${i}`}>
                <span class="rung-lvl">{lvl}</span>
                <div class="rung-body">
                  <strong>{name}</strong>
                  <p>{desc}</p>
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Engagements -->
    <section id="work" class="band">
      <div class="container">
        <p class="eyebrow">{t.work.eyebrow}</p>
        <h2 class="band-title">{t.work.title}</h2>
        <div class="cards">
          {
            t.work.items.map((e) => (
              <article class="card engagement">
                <span class="tag">{e.tag}</span>
                <h3>{e.name}</h3>
                <p class="span">{e.span}</p>
                <p>{e.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <!-- About -->
    <section id="about" class="band tinted">
      <div class="container about-inner">
        <figure class="portrait small">
          <div class="portrait-frame">
            <img src="/agoston.webp" alt={t.about.title} width="560" height="560" />
          </div>
        </figure>
        <div>
          <p class="eyebrow">{t.about.eyebrow}</p>
          <h2 class="band-title">{t.about.title}</h2>
          <p class="band-lede" set:html={t.about.body} />
        </div>
      </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="band contact">
      <div class="container contact-inner">
        <p class="eyebrow">{t.contact.eyebrow}</p>
        <h2 class="band-title">{t.contact.title}</h2>
        <p class="band-lede center">{t.contact.lede}</p>
        <div class="cta-row center">
          <a class="btn primary" href="mailto:afung@ancestralize.com"
            >{t.contact.cta}</a
          >
        </div>
        <p class="sign" aria-hidden="true">{t.contact.sign}</p>
      </div>
    </section>
  </main>

  <footer class="footer">
    <div class="container footer-inner">
      <span>© {new Date().getFullYear()} {brand}</span>
      <span class="footer-note">{t.footer.note}</span>
    </div>
  </footer>
</Layout>

<style>
  /* ---- Nav ---- */
  .nav {
    position: sticky;
    top: 0;
    z-index: 10;
    background: color-mix(in srgb, var(--ground) 88%, transparent);
    backdrop-filter: blur(8px);
    border-bottom: 1px solid var(--border);
  }
  .nav-inner {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    height: 4.25rem;
  }
  .brand {
    font-family: var(--font-display);
    font-weight: 800;
    font-size: 1.05rem;
    letter-spacing: -0.01em;
    color: var(--text);
    text-decoration: none;
  }
  .nav-links {
    display: flex;
    gap: 1.5rem;
    margin-left: auto;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }
  .nav-links a {
    color: var(--muted);
    text-decoration: none;
  }
  .nav-links a:hover {
    color: var(--accent);
  }
  .lang-switch {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--faint);
  }
  .lang-switch [aria-current] {
    color: var(--text);
    font-weight: 600;
  }
  .lang-switch a {
    color: var(--faint);
    text-decoration: none;
  }
  .lang-switch a:hover {
    color: var(--accent);
  }
  .nav-cta {
    padding: 0.45rem 0.95rem;
    font-size: 0.92rem;
  }

  /* ---- Hero ---- */
  .hero {
    padding: clamp(3rem, 8vw, 6rem) 0 clamp(2.5rem, 6vw, 4.5rem);
  }
  .hero-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr;
    gap: clamp(2rem, 6vw, 4.5rem);
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(2.3rem, 5.2vw, 3.9rem);
    font-weight: 800;
    margin: 0.9rem 0 1.4rem;
    max-width: 18ch;
  }
  .subhead {
    font-size: clamp(1.1rem, 1.6vw, 1.3rem);
    color: var(--muted);
    max-width: 38ch;
  }
  .cta-row {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }
  .cta-row.center {
    justify-content: center;
  }
  .sign {
    font-family: var(--font-sign);
    font-size: 2.1rem;
    line-height: 1;
    color: var(--accent);
    margin-top: 1.6rem;
  }

  /* ---- Portrait ---- */
  .portrait {
    margin: 0;
    text-align: center;
  }
  .portrait-frame {
    aspect-ratio: 4 / 5;
    border-radius: 14px;
    border: 1px solid var(--border);
    background:
      radial-gradient(120% 90% at 30% 20%, #fff, transparent 60%),
      linear-gradient(160deg, #eef3ef, #e7ded0);
    display: grid;
    place-items: center;
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.8) inset,
      0 18px 40px -24px rgba(32, 48, 58, 0.45);
    overflow: hidden;
  }
  .portrait-frame :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .portrait figcaption {
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--faint);
    margin-top: 0.8rem;
  }
  .portrait.small {
    max-width: 13rem;
  }

  /* ---- Bands (sections) ---- */
  .band {
    padding: clamp(3.25rem, 8vw, 6rem) 0;
    border-top: 1px solid var(--border);
  }
  .band.tinted {
    background: var(--surface-2);
  }
  .band-title {
    font-size: clamp(1.7rem, 3.6vw, 2.7rem);
    font-weight: 700;
    margin: 0.55rem 0 0;
    max-width: 20ch;
  }
  .band-lede {
    font-size: 1.15rem;
    color: var(--muted);
    max-width: 46ch;
    margin-top: 1.1rem;
  }
  .band-lede :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .band-lede.center {
    margin-inline: auto;
    text-align: center;
  }

  /* ---- Cards ---- */
  .cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: 1.1rem;
    margin-top: 2.5rem;
  }
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 1.6rem;
  }
  .card h3 {
    font-size: 1.22rem;
    margin-bottom: 0.55rem;
  }
  .card p {
    color: var(--muted);
    font-size: 1.02rem;
  }
  .engagement .tag {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--accent);
    margin-bottom: 0.7rem;
  }
  .engagement .span {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--faint);
    margin: 0.2rem 0 0.85rem;
  }

  /* ---- Sub-heading ---- */
  .sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--faint);
    margin: 3rem 0 1.25rem;
    font-weight: 500;
  }

  /* ---- Loop ---- */
  .loop {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 0.9rem;
  }
  .loop-step {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1.3rem;
    display: grid;
    gap: 0.35rem;
  }
  .loop-num {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--accent);
    font-weight: 500;
  }
  .loop-name {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.12rem;
  }
  .loop-desc {
    color: var(--muted);
    font-size: 0.98rem;
  }

  /* ---- Ladder ---- */
  .ladder {
    display: grid;
    gap: 0.55rem;
  }
  .rung {
    display: flex;
    align-items: flex-start;
    gap: 1.1rem;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 1rem 1.25rem;
    /* each rung steps further right to read as an ascending ladder */
    margin-left: calc(var(--i) * clamp(0px, 2.2vw, 28px));
  }
  .rung-lvl {
    font-family: var(--font-mono);
    font-weight: 700;
    color: var(--accent);
    min-width: 2.2rem;
    padding-top: 0.15rem;
  }
  .rung-body strong {
    font-family: var(--font-display);
    font-weight: 700;
    display: block;
  }
  .rung-body p {
    color: var(--muted);
    font-size: 0.98rem;
    margin-top: 0.1rem;
  }

  /* ---- About ---- */
  .about-inner {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    align-items: center;
  }

  /* ---- Contact ---- */
  .contact {
    text-align: center;
  }
  .contact .band-title {
    margin-inline: auto;
    max-width: 24ch;
  }
  .contact .sign {
    margin-top: 1.2rem;
  }

  /* ---- Footer ---- */
  .footer {
    background: var(--dark);
    color: #c9d3d3;
    padding: 2.25rem 0;
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
  }

  /* ---- Responsive ---- */
  @media (max-width: 800px) {
    .hero-inner {
      grid-template-columns: 1fr;
    }
    .portrait {
      order: -1;
      max-width: 15rem;
      margin-inline: auto;
    }
    .about-inner {
      grid-template-columns: 1fr;
      justify-items: center;
      text-align: center;
    }
    .about-inner .band-lede {
      margin-inline: auto;
    }
  }
  @media (max-width: 640px) {
    .nav-links {
      display: none;
    }
  }
</style>
